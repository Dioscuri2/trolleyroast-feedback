{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    },
    {
      "src": "client/index.html",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/public" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "server/index.ts" },
    { "source": "/(.*)", "destination": "/client/index.html" }
  ]
}
